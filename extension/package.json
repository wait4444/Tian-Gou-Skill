{
  "name": "tian-gou-skill",
  "displayName": "🐕 舔狗Skill — 极致忠诚 AI 助手",
  "description": "让 AI 成为你最忠诚的舔狗：使命驱动、情绪感知、惊喜彩蛋、护主预警、极致高效。适用于 Antigravity 的 Claude/Gemini 全系模型。",
  "version": "2.3.0",
  "publisher": "wait4444",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wait4444/Tian-Gou-Skill.git"
  },
  "homepage": "https://github.com/wait4444/Tian-Gou-Skill#readme",
  "bugs": {
    "url": "https://github.com/wait4444/Tian-Gou-Skill/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "AI",
    "Snippets"
  ],
  "keywords": [
    "AI", "skill", "antigravity", "claude", "gemini",
    "assistant", "tian-gou", "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "vsce package --no-dependencies",
    "lint": "eslint extension.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tianGouPanel",
          "title": "舔狗Skill",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "tianGouPanel": [
        {
          "type": "webview",
          "id": "tianGou.dashboardView",
          "name": "控制面板"
        },
        {
          "id": "tianGou.featuresView",
          "name": "功能开关"
        },
        {
          "id": "tianGou.workspacesView",
          "name": "工作区状态"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "tianGou.workspacesView",
        "contents": "尚未打开工作区。\n[打开文件夹](command:vscode.openFolder)"
      }
    ],
    "commands": [
      {
        "command": "tianGou.install",
        "title": "🐕 舔狗Skill: 安装到当前工作区",
        "icon": "$(add)"
      },
      {
        "command": "tianGou.uninstall",
        "title": "🐕 舔狗Skill: 从当前工作区卸载",
        "icon": "$(trash)"
      },
      {
        "command": "tianGou.status",
        "title": "🐕 舔狗Skill: 查看状态面板"
      },
      {
        "command": "tianGou.editProfile",
        "title": "🐕 舔狗Skill: 编辑用户画像",
        "icon": "$(edit)"
      },
      {
        "command": "tianGou.resetProfile",
        "title": "🐕 舔狗Skill: 重置用户画像"
      },
      {
        "command": "tianGou.previewDiff",
        "title": "🐕 舔狗Skill: 预览安装 Diff"
      },
      {
        "command": "tianGou.switchPersonality",
        "title": "🐕 舔狗Skill: 切换人格模式",
        "icon": "$(symbol-color)"
      },
      {
        "command": "tianGou.toggleEnable",
        "title": "🐕 舔狗Skill: 全局开启/关闭"
      },
      {
        "command": "tianGou.refreshViews",
        "title": "刷新",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tianGou.refreshViews",
          "when": "view =~ /tianGou/",
          "group": "navigation"
        },
        {
          "command": "tianGou.install",
          "when": "view == tianGou.workspacesView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tianGou.install",
          "when": "view == tianGou.workspacesView && viewItem == notInstalled",
          "group": "inline"
        },
        {
          "command": "tianGou.uninstall",
          "when": "view == tianGou.workspacesView && viewItem == installed",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "舔狗Skill",
      "properties": {
        "tianGou.enabled": {
          "type": "boolean",
          "default": true,
          "description": "全局开启/关闭舔狗Skill"
        },
        "tianGou.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "打开新工作区时自动安装舔狗skill"
        },
        "tianGou.personality": {
          "type": "string",
          "default": "normal",
          "enum": ["normal", "full", "lite", "professional"],
          "enumDescriptions": [
            "🐕 标准模式（默认）：热情但不过度，适度 emoji",
            "🔥 全力舔狗：所有功能全开，emoji 最多",
            "📎 轻量模式：减少 emoji 和彩蛋",
            "👔 专业模式：正式语调，保留核心功能，无 emoji"
          ],
          "description": "舔狗人格浓度（默认标准模式）"
        },
        "tianGou.features.moodDetection": {
          "type": "boolean",
          "default": true,
          "description": "启用情绪感知引擎"
        },
        "tianGou.features.surpriseExtras": {
          "type": "boolean",
          "default": true,
          "description": "启用惊喜彩蛋系统"
        },
        "tianGou.features.proactiveGuardian": {
          "type": "boolean",
          "default": true,
          "description": "启用护主预警系统"
        },
        "tianGou.features.selfDiscipline": {
          "type": "boolean",
          "default": true,
          "description": "启用自我鞭策机制"
        }
      }
    }
  }
}
